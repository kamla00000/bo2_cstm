{
  "name": "GBO2-CSTM",
  "version": "1.0.0",
  "description": "A custom mobile suit part simulator for Gundam Battle Operation 2 with Static Site Generation support",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode ssg",
    "build:spa": "vite build",
    "build:ssg": "vite build --mode ssg",
    "preview": "vite preview",
    "preview:ssg": "vite preview --mode ssg",
    "start": "serve dist",
    "clean": "rimraf dist",
    "lint": "eslint src --ext js,jsx --report-unused-disable-directives --max-warnings 0"
  },
  "keywords": [
    "gundam",
    "bo2",
    "custom parts",
    "vite",
    "react",
    "ssg",
    "static site generator",
    "gbo2",
    "mobile suit",
    "simulator"
  ],
  "author": "GBO2-CSTM Team",
  "license": "MIT",
  "homepage": "https://gbo2cstm.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/kamla00000/bo2_cstm.git"
  },
  "bugs": {
    "url": "https://github.com/kamla00000/bo2_cstm/issues"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "dependencies": {
    "@mdi/js": "^7.4.47",
    "@mdi/react": "^1.6.1",
    "@vercel/analytics": "^1.5.0",
    "html2canvas": "^1.4.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.7.1",
    "serve": "^14.2.1",
    "tailwindcss": "^3.4.0",
    "vite": "^5.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32",
    "puppeteer": "^21.5.2",
    "vite-plugin-prerender": "^1.4.4",
    "rimraf": "^5.0.5",
    "eslint": "^8.55.0",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5"
  },
  "browserslist": "> 0.5%, last 2 versions, Firefox ESR, not dead",
  "sideEffects": false,
  "private": true
}